loader.entrypoint.uri = "file:/usr/bin/python3"
loader.argv = ["python3", "simulate_attacks.py"]
loader.env.LD_LIBRARY_PATH = "/usr/local/lib:/usr/lib/x86_64-linux-gnu"

sgx.enclave_size = "512M"
sgx.thread_num = 4
sgx.isvprodid = 0
sgx.isvsvn = 0
sgx.remote_attestation = "none"

fs.mounts = [
    { uri = "file:/lib", path = "/lib" },
    { uri = "file:/usr/lib", path = "/usr/lib" },
]

sgx.trusted_files = [
    "file:/usr/bin/python3",
    "file:simulate_attacks.py",
]
